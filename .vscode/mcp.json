{
    "servers": {
        "superset": {
            "type": "http",
            "url": "http://localhost:5008/mcp"
        },
        "superset-innova": {
            "type": "http",
            "url": "http://innovapre.tirant.net:5008/mcp"
        },
        "postgres": {
            "command": "uvx",
            "args": [
                "--python", "3.12",
                "postgres-mcp",
                "postgresql://conversa:conversapassword@localhost:5432/conversa_analytics",
                "--access-mode=unrestricted"
            ]
        },
        "logfire": {
            "command": "/opt/homebrew/bin/uvx", // or the absolute /path/to/uvx
            "args": ["logfire-mcp@latest"],
            "env": {
                "LOGFIRE_READ_TOKEN": "${env:LOGFIRE_READ_TOKEN}"
            }
        },
        "context7": {
            "url": "https://mcp.context7.com/mcp"
        },
        "playwright": {
            "command": "npx",
            "args": ["@playwright/mcp@latest"]
        },
        "time": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "mcp/time",
                "--local-timezone",
                "Europe/Madrid"
            ]
        },
        "sequential-thinking": {
            "command": "docker",
            "args": [
            "run",
            "--rm",
            "-i",
            "mcp/sequentialthinking"
            ]
        },
        "hf-mcp-server": {
            "url": "https://huggingface.co/mcp",
            "headers": {
                "Authorization": "Bearer ${env:HF_TOKEN}"
            }
        }
