{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Current File (with Package Context)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
